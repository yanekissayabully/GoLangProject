# DriveBai Backend Configuration
# Copy this file to .env and update the values as needed.
# For Docker Compose, set these variables in your shell or use a .env file
# at the project root (next to docker-compose.yml).

# Server Configuration
PORT=8080
ENV=development

# Database Configuration
DATABASE_URL=postgres://drivebai:drivebai_secret@localhost:5432/drivebai?sslmode=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h


# Email Configuration (SendGrid)
# When SENDGRID_API_KEY is not set, emails are logged to console (dev mode).
# When set, emails are sent via SendGrid.
# IMPORTANT: The FROM email must be a verified sender identity in SendGrid.
# See: https://docs.sendgrid.com/ui/sending-email/sender-verification
# If not verified, SendGrid will return 4xx errors.

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@drivebai.com
SENDGRID_FROM_NAME=DriveBai


# Deep link scheme for mobile app (e.g., drivebai://reset-password?token=...)
APP_DEEPLINK_SCHEME=drivebai

# Base URL for the API (used for generating links in emails, etc.)
APP_BASE_URL=http://localhost:8080

UPLOAD_DIR=./uploads
