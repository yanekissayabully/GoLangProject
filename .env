# Server Configuration
PORT=8080
ENV=development

# Database Configuration
DATABASE_URL=postgres://drivebai:drivebai_secret@localhost:5432/drivebai?sslmode=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h

# SendGrid Configuration (optional for development)
# If not set, OTP codes will be logged to console
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@drivebai.com
SENDGRID_FROM_NAME=DriveBai

# Rate Limiting
OTP_RATE_LIMIT_PER_HOUR=5

# OTP Configuration
OTP_EXPIRY_MINUTES=10
